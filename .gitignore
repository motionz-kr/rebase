# ──────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────
node_modules/

# ──────────────────────────────────────────────
# Build output
# ──────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# electron-builder buildResources (signing entitlements, icons) live in this
# `build/` dir — it's source, not output, so keep it tracked despite `build/`.
!apps/desktop/build/
!apps/desktop/build/**

# Compiled Go engine binary (produced by `pnpm build:engine`)
apps/desktop/bin/

# Electron-builder installers (output: apps/desktop/release)
release/

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ──────────────────────────────────────────────
# Local config & secrets
# ──────────────────────────────────────────────
*.local
.env
.env.*
!.env.example

# ──────────────────────────────────────────────
# OS files
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────
# Editors / IDEs
# ──────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ──────────────────────────────────────────────
# Claude Code local session/state
# ──────────────────────────────────────────────
.claude/

# Playwright
apps/desktop/test-results/
apps/desktop/playwright-report/
