{
  "appId": "com.rebase.app",
  "productName": "Rebase",
  "publish": [
    {
      "provider": "github",
      "owner": "motionz-kr",
      "repo": "rebase",
      "releaseType": "release"
    }
  ],
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "compression": "maximum",
  "electronLanguages": ["en", "ko"],
  "files": [
    "dist/main/**/*",
    "dist/preload/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "bin",
      "to": "bin",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "../renderer/dist",
      "to": "renderer/dist",
      "filter": [
        "**/*"
      ]
    }
  ],
  "afterPack": "scripts/after-pack.cjs",
  "mac": {
    "category": "public.app-category.developer-tools",
    "target": ["dmg", "zip"],
    "identity": null
  },
  "win": {
    "target": ["nsis", "zip"],
    "publisherName": "Rebase"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true
  }
}
